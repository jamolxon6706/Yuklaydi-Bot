# Telegram
BOT_TOKEN=your_bot_token_here
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
LOCAL_API_URL=http://telegram-bot-api:8081

# Database
DATABASE_URL=postgresql+asyncpg://bot:bot_password@postgres:5432/yuklaydi_bot

# Redis
REDIS_URL=redis://redis:6379/0

# Genius API (get at genius.com/api-clients)
GENIUS_TOKEN=your_genius_token_here

# Musixmatch API (optional, fallback for Uzbek/non-English lyrics; get at developer.musixmatch.com)
MUSIXMATCH_TOKEN=

# Bot config
ADMIN_IDS=123456789,987654321
DEFAULT_LANG=uz
MAX_FILE_MB=2000
DOWNLOAD_DIR=/downloads
WORKER_CONCURRENCY=5

# Rate limiting
RATE_LIMIT_REQUESTS=10
RATE_LIMIT_WINDOW=60

# Logging
LOG_LEVEL=INFO




